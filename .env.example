# Optional: enable shared cloud feed, profiles, and likes (Supabase).
# Copy to `.env` or `.env.local` and fill with your project values.
# If you cannot create dotfiles, copy these two lines into `supabase.env` instead
# (same folder as package.json; that file is gitignored).
# Run `supabase/migrations/001_initial.sql` in the SQL editor, enable Anonymous
# auth (Authentication → Providers), and ensure bucket `drawing-images` exists.

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key
